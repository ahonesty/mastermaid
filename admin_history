<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Master Maid | ประวัติการทำงาน</title>
    
    <script src="https://www.gstatic.com/firebasejs/9.0.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.0.0/firebase-database-compat.js"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root { --primary: #0A1931; --gold: #D4AF37; --gold-light: #F9F1D7; --bg: #F4F7F6; }
        body { font-family: 'Sarabun', sans-serif; background: var(--bg); margin: 0; color: #333; }
        
        .nav-admin { background: var(--primary); padding: 15px 5%; color: white; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; }
        .nav-admin h2 { margin: 0; font-size: 20px; color: var(--gold); }
        .btn-back { color: white; text-decoration: none; font-size: 14px; border: 1px solid rgba(255,255,255,0.3); padding: 8px 15px; border-radius: 10px; transition: 0.3s; }
        .btn-back:hover { background: rgba(255,255,255,0.1); }

        .container { max-width: 1100px; margin: 30px auto; padding: 0 20px; }

        /* Stats Cards */
        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: white; padding: 25px; border-radius: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); text-align: center; border-bottom: 5px solid var(--gold); }
        .stat-card i { font-size: 30px; color: var(--gold); margin-bottom: 10px; }
        .stat-card h4 { margin: 5px 0; color: #666; font-size: 14px; }
        .stat-card .val { font-size: 28px; font-weight: 700; color: var(--primary); }

        /* Table Style */
        .table-container { background: white; border-radius: 25px; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; }
        thead { background: #f8f9fa; border-bottom: 2px solid #eee; }
        th { padding: 20px; text-align: left; font-size: 14px; color: var(--primary); text-transform: uppercase; letter-spacing: 1px; }
        td { padding: 20px; border-bottom: 1px solid #f0f0f0; font-size: 15px; vertical-align: middle; }
        tr:last-child td { border-bottom: none; }
        tr:hover { background: #fafafa; }

        /* Badges */
        .badge { padding: 6px 12px; border-radius: 50px; font-size: 12px; font-weight: 600; }
        .badge-success { background: #E2F6ED; color: #2ecc71; } /* เสร็จสิ้น */
        .badge-info { background: #E1F5FE; color: #03A9F4; }    /* รับงานแล้ว */
        
        .maid-name { font-weight: 700; color: var(--primary); }
        .job-price { color: var(--gold-dark); font-weight: 700; }
        
        @media (max-width: 768px) {
            th:nth-child(4), td:nth-child(4) { display: none; } /* ซ่อนประเภทงานในมือถือ */
        }
    </style>
</head>
<body>

    <div class="nav-admin">
        <h2>MASTER MAID HISTORY</h2>
        <a href="admin_post.html" class="btn-back"><i class="fas fa-home"></i> กลับหน้าจัดการ</a>
    </div>

    <div class="container">
        <div class="stats-row">
            <div class="stat-card">
                <i class="fas fa-check-double"></i>
                <h4>งานที่จบแล้ว</h4>
                <div class="val" id="countDone">0</div>
            </div>
            <div class="stat-card">
                <i class="fas fa-wallet"></i>
                <h4>รายได้สะสม (บาท)</h4>
                <div class="val" id="totalRev">0</div>
            </div>
            <div class="stat-card">
                <i class="fas fa-users"></i>
                <h4>แม่บ้านที่ทำงานล่าสุด</h4>
                <div class="val" id="lastMaid">-</div>
            </div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>วันที่ / เวลา</th>
                        <th>ลูกค้า</th>
                        <th>พนักงานผู้รับงาน</th>
                        <th>ประเภทที่พัก</th>
                        <th>ค่าบริการ</th>
                        <th>สถานะ</th>
                    </tr>
                </thead>
                <tbody id="historyList">
                    </tbody>
            </table>
        </div>
    </div>

<script>
    // --- Firebase Configuration ---
    const firebaseConfig = { 
        apiKey: "AIzaSyCTWK2HDu1QPn54YJMaTmJ5Xk8MLis3PAU", 
        databaseURL: "https://mastermaid-ubon-default-rtdb.asia-southeast1.firebasedatabase.app" 
    };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    function fetchHistory() {
        // ดึงข้อมูลจาก available_jobs (เฉพาะงานที่ถูกรับไปแล้ว status != available)
        db.ref('available_jobs').on('value', (snapshot) => {
            const data = snapshot.val();
            const list = document.getElementById('historyList');
            list.innerHTML = "";
            
            let doneCount = 0;
            let revenue = 0;
            let lastMaidName = "-";

            if (!data) return;

            // แปลงเป็น Array และเรียงลำดับตามเวลาล่าสุด
            const jobs = Object.keys(data)
                .map(key => ({ id: key, ...data[key] }))
                .filter(j => j.status !== "available") // เอาเฉพาะงานที่มีคนรับแล้ว
                .sort((a, b) => (b.postedAt || 0) - (a.postedAt || 0));

            jobs.forEach(job => {
                const isDone = job.status === "completed" || job.status === "finished";
                if (isDone) {
                    doneCount++;
                    revenue += parseInt(job.price || 0);
                }
                lastMaidName = job.acceptedBy || job.maid_name || "-";

                const dateStr = job.booking_date || "ไม่ระบุวันที่";
                const timeStr = job.booking_time || "";
                
                const row = `
                    <tr>
                        <td>
                            <div style="font-weight:600;">${dateStr}</div>
                            <small style="color:#888;">${timeStr} น.</small>
                        </td>
                        <td>
                            <div style="font-weight:600;">คุณ ${job.title}</div>
                            <small>${job.phone || ''}</small>
                        </td>
                        <td class="maid-name"><i class="fas fa-user-circle"></i> ${lastMaidName}</td>
                        <td><small>${job.property_type || '-'}</small></td>
                        <td class="job-price">${parseInt(job.price || 0).toLocaleString()}.-</td>
                        <td>
                            <span class="badge ${isDone ? 'badge-success' : 'badge-info'}">
                                ${isDone ? '<i class="fas fa-check"></i> สำเร็จ' : '<i class="fas fa-clock"></i> กำลังทำ'}
                            </span>
                        </td>
                    </tr>
                `;
                list.innerHTML += row;
            });

            // อัปเดตตัวเลข Stats
            document.getElementById('countDone').innerText = doneCount;
            document.getElementById('totalRev').innerText = revenue.toLocaleString();
            document.getElementById('lastMaid').innerText = lastMaidName;
        });
    }

    window.onload = fetchHistory;
</script>
</body>
</html>
